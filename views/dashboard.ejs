cat > views/dashboard.ejs << 'ENDOFFILE'
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Dossier — Blue Ocean</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="dashboard-page">
  <header class="site-header">
    <div class="header-left">
      <span class="header-brand">BLUE OCEAN</span>
      <span class="header-tagline"><em>The Art of the Impossible</em></span>
    </div>
    <div class="header-right">
      <span class="header-dossier">Dossier <strong><%= user.username %></strong></span>
      <a href="/logout" class="header-signout">Sign out</a>
    </div>
  </header>

  <main class="dashboard-main">
    <div class="dashboard-intro">
      <div>
        <p class="intro-label">YOUR PRIVATE RECORD</p>
        <h1 class="intro-greeting">Good morning, <em class="gold"><%= user.first_name || 'Member' %></em></h1>
        <p class="intro-desc">This is your confidential workstream for 18 July. Every module below is private to you. Your pre-assessment feeds your maturity report; your report anchors your canvas; your canvas produces your 90-day plan. Nothing is shared unless you choose to pin it to the Commitment Wall at day-end.</p>
      </div>
      <div class="intro-meta">
        <% if (user.organization) { %><div><strong><%= user.organization %></strong></div><% } %>
        <% if (user.table_number) { %><div>Table <strong><%= user.table_number %></strong></div><% } %>
        <% if (user.cohort) { %><div>Cohort band: <strong><%= user.cohort %></strong></div><% } %>
      </div>
    </div>

    <div class="divider"></div>

    <div class="module-grid">
      <% modules.forEach(function(mod, index) { %>
        <div class="module-card <%= index === 0 ? 'module-featured' : '' %> <%= mod.status === 'locked' ? 'locked' : '' %>">
          <div class="module-header">
            <span class="module-label">Module <%= String(mod.module_number).padStart(2, '0') %> &middot; <%= mod.subtitle %></span>
            <% if (mod.status === 'complete') { %>
              <span class="badge badge-complete">Complete</span>
            <% } else if (mod.status === 'in_progress') { %>
              <span class="badge badge-progress">In progress</span>
            <% } else if (mod.status === 'unlocked') { %>
              <span class="badge badge-ready">Ready</span>
            <% } else { %>
              <span class="badge badge-locked">Locked</span>
            <% } %>
          </div>

          <% if (index === 0) { %>
            <h2 class="module-title">AI Maturity <em style="font-style:italic"><%= mod.title.includes('Assessment') ? 'Assessment' : '' %></em></h2>
          <% } else { %>
            <h2 class="module-title"><%= mod.title %></h2>
          <% } %>

          <p class="module-desc"><%= mod.description %></p>

          <% if (mod.status === 'complete' && mod.completed_at) { %>
            <p class="module-completed-date">You completed this on <%= new Date(mod.completed_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }) %>. Your responses power every downstream module in this dossier.</p>
          <% } %>

          <div class="module-action">
            <% if (mod.status === 'complete') { %>
              <% if (mod.module_type === 'assessment') { %>
                <a href="/module/<%= mod.module_number %>/responses" class="module-link">View responses →</a>
              <% } else if (mod.module_type === 'report') { %>
                <a href="#" class="module-link" onclick="alert('PDF download will be available soon.')">Download PDF →</a>
              <% } %>
            <% } else if (mod.status === 'unlocked' || mod.status === 'in_progress') { %>
              <% if (mod.module_type === 'assessment') { %>
                <a href="/module/<%= mod.module_number %>" class="module-link">Start assessment →</a>
              <% } else if (mod.module_type === 'report') { %>
                <a href="#" class="module-link" onclick="alert('PDF download will be available soon.')">Download PDF →</a>
              <% } else { %>
                <a href="/module/<%= mod.module_number %>" class="module-link">Open <%= mod.title.toLowerCase() %> →</a>
              <% } %>
            <% } else { %>
              <%
                let unlockHint = 'Coming soon';
                const prevMod = modules.find(m => m.module_number === mod.module_number - 1);
                if (prevMod) unlockHint = 'Unlocks after ' + prevMod.title.toLowerCase();
              %>
              <span class="module-link-disabled"><%= unlockHint %></span>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </main>
</body>
</html>
ENDOFFILE