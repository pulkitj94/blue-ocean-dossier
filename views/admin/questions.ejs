<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Questions — Blue Ocean Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .question-cell { max-width: 260px; }
    .tooltip-cell { max-width: 180px; font-size: 0.8rem; color: #888; }
    .inactive-row { opacity: 0.5; }
    .edit-panel { background: #f8f8f8; border: 1px solid #ddd; padding: 1.5rem; margin-top: 1rem; border-radius: 6px; }
    .edit-panel h3 { margin-bottom: 1rem; }
    textarea.full-width { width: 100%; padding: 0.5rem; font-family: inherit; font-size: 0.9rem; border: 1px solid #ddd; border-radius: 4px; resize: vertical; }
    .filter-bar { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; padding: 0.8rem 1rem; background: #f8f8f8; border-radius: 6px; }
    .filter-bar label { font-weight: 500; font-size: 0.85rem; }
    .filter-bar select { padding: 0.4rem 0.8rem; border: 1px solid #ddd; border-radius: 4px; font-size: 0.85rem; }
    .move-btn { background: none; border: 1px solid #ccc; cursor: pointer; padding: 2px 8px; border-radius: 3px; font-size: 14px; transition: all 0.2s; }
    .move-btn:hover { background: #333; color: #fff; border-color: #333; }
    .move-btns { display: flex; gap: 4px; }
    .module-badge { font-size: 0.7rem; padding: 2px 6px; background: #eee; border-radius: 3px; color: #666; }
  </style>
</head>
<body>
  <nav class="admin-nav">
    <div class="nav-brand">🌊 Blue Ocean Admin</div>
    <div class="nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/admin/users">Users</a>
      <a href="/admin/questions" class="active">Questions</a>
      <a href="/admin/modules">Modules</a>
      <a href="/admin/responses">Responses</a>
      <a href="/admin/logout" class="nav-logout">Sign Out</a>
    </div>
  </nav>

  <main class="admin-main">
    <div class="page-header">
      <h1>Question Management</h1>
      <button class="btn-admin" onclick="showAddForm()">+ Add Question</button>
    </div>

    <!-- Module Filter -->
    <div class="filter-bar">
      <label>Filter by Module:</label>
      <select id="moduleFilter" onchange="filterByModule()">
        <option value="all">All Modules</option>
        <% modules.forEach(function(m) { %>
          <option value="<%= m.id %>">Module <%= m.module_number %>: <%= m.title %></option>
        <% }); %>
      </select>
      <span id="questionCount" style="margin-left:auto;font-size:0.85rem;color:#888;"></span>
    </div>

    <!-- Add Question Form -->
    <div id="addForm" class="form-panel" style="display:none;">
      <h3>Add New Question</h3>
      <div class="form-row">
        <div class="form-col">
          <label>Module</label>
          <select id="qModule">
            <% modules.forEach(function(m) { %>
              <option value="<%= m.id %>">Module <%= m.module_number %>: <%= m.title %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-col">
          <label>Question Number</label>
          <input type="number" id="qNumber" value="<%= questions.length + 1 %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col">
          <label>Pillar / Category</label>
          <input type="text" id="qPillar" placeholder="e.g. Strategy & Vision">
        </div>
        <div class="form-col">
          <label>Response Type</label>
          <select id="qType" onchange="toggleOptions()">
            <option value="scale">Scale 1-5</option>
            <option value="single_select">Single Select</option>
            <option value="multi_select">Multi Select</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Question Text</label>
          <textarea id="qText" rows="2" placeholder="Does your organization have..."></textarea>
        </div>
      </div>
      <div class="form-row" id="optionsRow" style="display:none;">
        <div class="form-col full">
          <label>Options (comma-separated)</label>
          <input type="text" id="qOptions" placeholder="Yes, Partially, No">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Scoring Logic</label>
          <input type="text" id="qScoring" placeholder="Yes=5, Partially=3, No=1">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Tooltip (help text shown on hover)</label>
          <textarea id="qTooltip" rows="2" placeholder="A documented AI strategy is a written plan..."></textarea>
        </div>
      </div>
      <div class="form-row" id="scaleLabelsRow">
        <div class="form-col full">
          <label>Scale Labels (comma-separated, 5 values for scale questions)</label>
          <input type="text" id="qScaleLabels" placeholder="No plan, Early discussions, Strategy drafted, Partially integrated, Fully integrated">
        </div>
      </div>
      <div class="form-actions">
        <button class="btn-admin" onclick="addQuestion()">Add Question</button>
        <button class="btn-admin secondary" onclick="document.getElementById('addForm').style.display='none'">Cancel</button>
      </div>
    </div>

    <!-- Edit Question Panel -->
    <div id="editPanel" class="edit-panel" style="display:none;">
      <h3>Edit Question: <span id="editQNum"></span></h3>
      <input type="hidden" id="editId">
      <div class="form-row">
        <div class="form-col">
          <label>Pillar / Category</label>
          <input type="text" id="editPillar">
        </div>
        <div class="form-col">
          <label>Response Type</label>
          <select id="editType" onchange="toggleEditOptions()">
            <option value="scale">Scale 1-5</option>
            <option value="single_select">Single Select</option>
            <option value="multi_select">Multi Select</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Question Text</label>
          <textarea id="editText" rows="2" class="full-width"></textarea>
        </div>
      </div>
      <div class="form-row" id="editOptionsRow">
        <div class="form-col full">
          <label>Options (comma-separated)</label>
          <input type="text" id="editOptions">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Scoring Logic</label>
          <input type="text" id="editScoring">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Tooltip (help text shown on hover)</label>
          <textarea id="editTooltip" rows="3" class="full-width"></textarea>
        </div>
      </div>
      <div class="form-row" id="editScaleLabelsRow">
        <div class="form-col full">
          <label>Scale Labels (comma-separated, 5 values)</label>
          <input type="text" id="editScaleLabels" placeholder="No plan, Early discussions, Strategy drafted, Partially integrated, Fully integrated">
        </div>
      </div>
      <div class="form-actions">
        <button class="btn-admin" onclick="saveEdit()">Save Changes</button>
        <button class="btn-admin secondary" onclick="document.getElementById('editPanel').style.display='none'">Cancel</button>
      </div>
    </div>

    <!-- Questions Table -->
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>#</th>
            <th>Pillar</th>
            <th>Question</th>
            <th>Tooltip</th>
            <th>Type</th>
            <th>Options</th>
            <th>Active</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="questionsBody">
          <% questions.forEach(function(q, index) { %>
            <tr class="<%= q.is_active ? '' : 'inactive-row' %> q-row" data-module-id="<%= q.module_id %>" data-qid="<%= q.id %>" data-sort="<%= q.sort_order %>">
              <td>
                <div class="move-btns">
                  <button class="move-btn" onclick="moveQuestion(<%= q.id %>, 'up')" title="Move up">↑</button>
                  <button class="move-btn" onclick="moveQuestion(<%= q.id %>, 'down')" title="Move down">↓</button>
                </div>
              </td>
              <td>Q<%= q.question_number %> <span class="module-badge">M<%= q.module_title ? q.module_title.charAt(0) : '' %></span></td>
              <td><%= q.pillar %></td>
              <td class="question-cell"><%= q.question_text %></td>
              <td class="tooltip-cell"><%= q.tooltip ? q.tooltip.substring(0, 50) + (q.tooltip.length > 50 ? '...' : '') : '—' %></td>
              <td><code><%= q.response_type %></code></td>
              <td class="options-cell"><%= q.parsedOptions.length > 0 ? q.parsedOptions.join(', ') : '1-5 scale' %></td>
              <td><%= q.is_active ? '✅' : '❌' %></td>
              <td>
                <button class="btn-admin small" onclick='editQuestion(<%- JSON.stringify({id:q.id, num:q.question_number, pillar:q.pillar, text:q.question_text, type:q.response_type, options:q.parsedOptions.join(", "), scoring:q.scoring_logic||"", tooltip:q.tooltip||"", scaleLabels:q.scale_labels||""}) %>)'>Edit</button>
                <button class="btn-admin small" onclick="toggleActive(<%= q.id %>, <%= q.is_active %>)">
                  <%= q.is_active ? 'Disable' : 'Enable' %>
                </button>
                <button class="btn-danger small" onclick="deleteQuestion(<%= q.id %>)">Delete</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </main>

  <script>
    // Module filter
    function filterByModule() {
      const val = document.getElementById('moduleFilter').value;
      const rows = document.querySelectorAll('.q-row');
      let count = 0;
      rows.forEach(row => {
        if (val === 'all' || row.dataset.moduleId === val) {
          row.style.display = '';
          count++;
        } else {
          row.style.display = 'none';
        }
      });
      document.getElementById('questionCount').textContent = count + ' question' + (count !== 1 ? 's' : '');
    }
    filterByModule(); // init count

    function showAddForm() { document.getElementById('addForm').style.display = 'block'; }

    function toggleOptions() {
      const type = document.getElementById('qType').value;
      document.getElementById('optionsRow').style.display = type === 'scale' ? 'none' : 'block';
      document.getElementById('scaleLabelsRow').style.display = type === 'scale' ? 'block' : 'none';
    }

    function toggleEditOptions() {
      const type = document.getElementById('editType').value;
      document.getElementById('editOptionsRow').style.display = type === 'scale' ? 'none' : 'block';
      document.getElementById('editScaleLabelsRow').style.display = type === 'scale' ? 'block' : 'none';
    }

    async function addQuestion() {
      const optionsStr = document.getElementById('qOptions').value;
      const options = optionsStr ? optionsStr.split(',').map(s => s.trim()) : [];
      const scaleLabelsStr = document.getElementById('qScaleLabels').value;
      const scaleLabels = scaleLabelsStr ? JSON.stringify(scaleLabelsStr.split(',').map(s => s.trim())) : '';

      const body = {
        module_id: parseInt(document.getElementById('qModule').value),
        question_number: parseInt(document.getElementById('qNumber').value),
        pillar: document.getElementById('qPillar').value,
        question_text: document.getElementById('qText').value,
        response_type: document.getElementById('qType').value,
        options: JSON.stringify(options),
        scoring_logic: document.getElementById('qScoring').value,
        tooltip: document.getElementById('qTooltip').value,
        scale_labels: scaleLabels,
      };

      const res = await fetch('/admin/questions/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.error || 'Failed to add question');
    }

    function editQuestion(q) {
      document.getElementById('editId').value = q.id;
      document.getElementById('editQNum').textContent = 'Q' + q.num;
      document.getElementById('editPillar').value = q.pillar;
      document.getElementById('editText').value = q.text;
      document.getElementById('editType').value = q.type;
      document.getElementById('editOptions').value = q.options;
      document.getElementById('editScoring').value = q.scoring;
      document.getElementById('editTooltip').value = q.tooltip;
      let labels = '';
      try { labels = JSON.parse(q.scaleLabels || '[]').join(', '); } catch(e) { labels = q.scaleLabels || ''; }
      document.getElementById('editScaleLabels').value = labels;
      toggleEditOptions();
      document.getElementById('editPanel').style.display = 'block';
      document.getElementById('editPanel').scrollIntoView({ behavior: 'smooth' });
    }

    async function saveEdit() {
      const id = document.getElementById('editId').value;
      const type = document.getElementById('editType').value;
      const optionsStr = document.getElementById('editOptions').value;
      const options = optionsStr ? optionsStr.split(',').map(s => s.trim()) : [];
      const scaleLabelsStr = document.getElementById('editScaleLabels').value;
      const scaleLabels = scaleLabelsStr ? JSON.stringify(scaleLabelsStr.split(',').map(s => s.trim())) : '';

      const body = {
        pillar: document.getElementById('editPillar').value,
        question_text: document.getElementById('editText').value,
        response_type: type,
        options: JSON.stringify(options),
        scoring_logic: document.getElementById('editScoring').value,
        tooltip: document.getElementById('editTooltip').value,
        scale_labels: scaleLabels,
      };

      const res = await fetch('/admin/questions/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.error || 'Failed to update');
    }

    async function moveQuestion(id, direction) {
      const res = await fetch('/admin/questions/' + id + '/move', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ direction })
      });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.error || 'Cannot move further');
    }

    async function toggleActive(id, current) {
      await fetch('/admin/questions/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_active: current ? 0 : 1 })
      });
      location.reload();
    }

    async function deleteQuestion(id) {
      if (!confirm('Delete this question? Existing responses will remain.')) return;
      await fetch('/admin/questions/' + id, { method: 'DELETE' });
      location.reload();
    }
  </script>
</body>
</html>