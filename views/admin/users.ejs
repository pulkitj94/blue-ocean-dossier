<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users — Blue Ocean Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <nav class="admin-nav">
    <div class="nav-brand">🌊 Blue Ocean Admin</div>
    <div class="nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/admin/users" class="active">Users</a>
      <a href="/admin/questions">Questions</a>
      <a href="/admin/modules">Modules</a>
      <a href="/admin/responses">Responses</a>
      <a href="/admin/logout" class="nav-logout">Sign Out</a>
    </div>
  </nav>

  <main class="admin-main">
    <div class="page-header">
      <h1>User Management</h1>
      <button class="btn-admin" onclick="showCreateForm()">+ Create User</button>
    </div>

    <!-- Create User Form (hidden by default) -->
    <div id="createForm" class="form-panel" style="display:none;">
      <h3>Create New Respondent</h3>
      <div class="form-row">
        <div class="form-col">
          <label>Username</label>
          <input type="text" id="newUsername" placeholder="">
        </div>
        <div class="form-col">
          <label>Passcode (auto-generated if blank)</label>
          <input type="text" id="newPassword" placeholder="">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col">
          <label>First Name</label>
          <input type="text" id="newFirstName" placeholder="">
        </div>
        <div class="form-col">
          <label>Last Name</label>
          <input type="text" id="newLastName" placeholder="">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col">
          <label>Designation</label>
          <input type="text" id="newDesignation" placeholder="">
        </div>
        <div class="form-col">
          <label>Organization</label>
          <input type="text" id="newOrg" placeholder="">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col full">
          <label>Email</label>
          <input type="email" id="newEmail" placeholder="">
        </div>
      </div>
      <div class="form-actions">
        <button class="btn-admin" onclick="createUser()">Create User</button>
        <button class="btn-admin secondary" onclick="hideCreateForm()">Cancel</button>
      </div>

      <!-- Credentials display -->
      <div id="credentialsDisplay" style="display:none;" class="credentials-box">
        <h4>✅ User Created — Share these credentials:</h4>
        <p><strong>Username:</strong> <span id="createdUsername"></span></p>
        <p><strong>Passcode:</strong> <span id="createdPassword"></span></p>
        <button class="btn-admin small" onclick="copyCredentials()">Copy to Clipboard</button>
      </div>
    </div>

    <!-- User List -->
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Username</th>
            <th>Name</th>
            <th>Email</th>
            <th>Organization</th>
            <th>Designation</th>
            <th>Responses</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr><td colspan="8" class="empty-state">No respondents yet. Create your first user above.</td></tr>
          <% } %>
          <% users.forEach(function(u) { %>
            <tr>
              <td><code><%= u.username %></code></td>
              <td><%= u.first_name %> <%= u.last_name %></td>
              <td><%= u.email || '—' %></td>
              <td><%= u.organization || '—' %></td>
              <td><%= u.designation || '—' %></td>
              <td><%= u.response_count %></td>
              <td><%= new Date(u.created_at).toLocaleDateString() %></td>
              <td>
                <button class="btn-admin small" onclick="resetPasscode(<%= u.id %>, '<%= u.username %>')">Reset Passcode</button>
                <button class="btn-admin small" onclick="editUser(<%= u.id %>, '<%= u.first_name %>', '<%= u.last_name %>', '<%= u.designation || '' %>', '<%= u.organization || '' %>')">Edit</button>
                <button class="btn-danger small" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')">Delete</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Edit User Modal -->
    <div id="editModal" class="form-panel" style="display:none;margin-top:1rem;">
      <h3>Edit User: <span id="editUsername"></span></h3>
      <input type="hidden" id="editUserId">
      <div class="form-row">
        <div class="form-col">
          <label>First Name</label>
          <input type="text" id="editFirstName">
        </div>
        <div class="form-col">
          <label>Last Name</label>
          <input type="text" id="editLastName">
        </div>
      </div>
      <div class="form-row">
        <div class="form-col">
          <label>Designation</label>
          <input type="text" id="editDesignation">
        </div>
        <div class="form-col">
          <label>Organization</label>
          <input type="text" id="editOrganization">
        </div>
      </div>
      <div class="form-actions">
        <button class="btn-admin" onclick="saveEdit()">Save Changes</button>
        <button class="btn-admin secondary" onclick="document.getElementById('editModal').style.display='none'">Cancel</button>
      </div>
    </div>

    <!-- Passcode Reset Display -->
    <div id="passcodeDisplay" class="credentials-box" style="display:none;margin-top:1rem;">
      <h4>🔑 New Passcode Generated</h4>
      <p><strong>Username:</strong> <span id="resetUsername"></span></p>
      <p><strong>New Passcode:</strong> <span id="resetPasscode"></span></p>
      <button class="btn-admin small" onclick="copyResetCredentials()">Copy to Clipboard</button>
    </div>
  </main>

  <script>
    function showCreateForm() { 
      document.getElementById('createForm').style.display = 'block';
      document.getElementById('credentialsDisplay').style.display = 'none';
    }
    function hideCreateForm() { document.getElementById('createForm').style.display = 'none'; }

    async function createUser() {
      const body = {
        username: document.getElementById('newUsername').value,
        password: document.getElementById('newPassword').value,
        first_name: document.getElementById('newFirstName').value,
        last_name: document.getElementById('newLastName').value,
        designation: document.getElementById('newDesignation').value,
        organization: document.getElementById('newOrg').value,
        email: document.getElementById('newEmail').value,
      };

      const res = await fetch('/admin/users/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      const data = await res.json();
      if (data.success) {
        document.getElementById('createdUsername').textContent = data.user.username;
        document.getElementById('createdPassword').textContent = data.user.password;
        document.getElementById('credentialsDisplay').style.display = 'block';
      } else {
        alert(data.error || 'Failed to create user');
      }
    }

    function copyCredentials() {
      const u = document.getElementById('createdUsername').textContent;
      const p = document.getElementById('createdPassword').textContent;
      navigator.clipboard.writeText('Username: ' + u + '\nPasscode: ' + p);
      alert('Credentials copied!');
    }

    async function resetPasscode(id, username) {
      if (!confirm('Generate a new passcode for ' + username + '?')) return;
      const res = await fetch('/admin/users/' + id + '/reset-passcode', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        document.getElementById('resetUsername').textContent = username;
        document.getElementById('resetPasscode').textContent = data.newPasscode;
        document.getElementById('passcodeDisplay').style.display = 'block';
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      } else {
        alert('Failed to reset passcode');
      }
    }

    function copyResetCredentials() {
      const u = document.getElementById('resetUsername').textContent;
      const p = document.getElementById('resetPasscode').textContent;
      navigator.clipboard.writeText('Username: ' + u + '\nPasscode: ' + p);
      alert('Credentials copied!');
    }

    function editUser(id, firstName, lastName, designation, organization) {
      document.getElementById('editUserId').value = id;
      document.getElementById('editUsername').textContent = firstName + ' ' + lastName;
      document.getElementById('editFirstName').value = firstName;
      document.getElementById('editLastName').value = lastName;
      document.getElementById('editDesignation').value = designation;
      document.getElementById('editOrganization').value = organization;
      document.getElementById('editModal').style.display = 'block';
      document.getElementById('editModal').scrollIntoView({ behavior: 'smooth' });
    }

    async function saveEdit() {
      const id = document.getElementById('editUserId').value;
      const body = {
        first_name: document.getElementById('editFirstName').value,
        last_name: document.getElementById('editLastName').value,
        designation: document.getElementById('editDesignation').value,
        organization: document.getElementById('editOrganization').value,
      };
      const res = await fetch('/admin/users/' + id + '/edit', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) { location.reload(); }
      else { alert(data.error || 'Failed to update'); }
    }

    async function deleteUser(id, username) {
      if (!confirm('Delete user ' + username + '? This will remove all their responses.')) return;
      await fetch('/admin/users/' + id, { method: 'DELETE' });
      location.reload();
    }
  </script>
</body>
</html>