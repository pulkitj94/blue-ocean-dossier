<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= module.title %> — Blue Ocean</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    /* Tooltip */
    .q-tooltip-wrap { position: relative; display: inline-block; margin-left: 8px; cursor: help; vertical-align: middle; }
    .q-tooltip-icon { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: var(--rule-soft, #ddd6c4); color: var(--ink-soft, #4a4640); font-family: var(--serif); font-size: 12px; font-style: italic; font-weight: 600; }
    .q-tooltip-text { visibility: hidden; opacity: 0; position: absolute; bottom: 130%; left: 50%; transform: translateX(-50%); width: 300px; background: var(--ink, #1a1916); color: var(--ivory, #f4f1ea); font-family: var(--sans, Inter, sans-serif); font-size: 13px; font-weight: 400; line-height: 1.6; padding: 14px 16px; border-radius: 4px; z-index: 100; transition: opacity 0.2s; box-shadow: 0 8px 24px rgba(0,0,0,0.25); }
    .q-tooltip-text::after { content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border: 6px solid transparent; border-top-color: var(--ink, #1a1916); }
    .q-tooltip-wrap:hover .q-tooltip-text { visibility: visible; opacity: 1; }

    /* Likert scale with labels */
    .likert-group { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .likert-options { display: flex; gap: 0; width: 100%; max-width: 560px; justify-content: center; }
    .likert-option { flex: 1; display: flex; flex-direction: column; align-items: center; cursor: pointer; padding: 8px 4px; transition: all 0.2s; }
    .likert-option input { display: none; }
    .likert-circle { display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; border: 2px solid var(--rule, #c9c2b0); border-radius: 50%; font-family: var(--mono); font-size: 14px; color: var(--ink-soft, #4a4640); transition: all 0.2s; margin-bottom: 6px; }
    .likert-option input:checked + .likert-circle { background: var(--ink, #1a1916); border-color: var(--ink); color: var(--ivory, #f4f1ea); font-weight: 500; }
    .likert-option:hover .likert-circle { border-color: var(--ink, #1a1916); }
    .likert-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.05em; color: var(--ink-muted, #8a857c); text-align: center; line-height: 1.3; max-width: 90px; }
    .likert-option input:checked ~ .likert-label { color: var(--ink, #1a1916); font-weight: 500; }

    /* Centered options */
    .select-group { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; padding: 8px 0; }
    .select-pill { display: inline-block; padding: 10px 20px; border: 1px solid var(--rule, #c9c2b0); font-size: 14px; transition: all 0.2s; border-radius: 24px; color: var(--ink-soft, #4a4640); cursor: pointer; }
    .select-option input:checked + .select-pill { background: var(--ink, #1a1916); color: var(--ivory, #f4f1ea); border-color: var(--ink); }
    .select-option:hover .select-pill { border-color: var(--ink, #1a1916); }

    /* Review & Thank You */
    .review-section { display: none; }
    .review-section.active { display: block; }
    .thankyou-screen { display: none; text-align: center; padding: 80px 20px; }
    .thankyou-screen.active { display: block; }
    .thankyou-screen h1 { font-family: var(--serif); font-size: 48px; font-weight: 500; margin-bottom: 16px; letter-spacing: -0.02em; }
    .thankyou-screen h1 em { font-style: italic; color: var(--accent, #6b1f1f); }
    .thankyou-screen .thankyou-desc { color: var(--ink-soft); font-size: 16px; line-height: 1.7; max-width: 560px; margin: 0 auto 32px; }
    .thankyou-next { margin-bottom: 40px; }
    .thankyou-next h3 { font-family: var(--mono); font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 12px; }
    .thankyou-next p { color: var(--ink-soft); font-size: 15px; line-height: 1.7; max-width: 480px; margin: 0 auto; }
    .thankyou-next p em { font-style: italic; color: var(--accent, #6b1f1f); }
    .redirect-note { font-family: var(--mono); font-size: 11px; color: var(--ink-muted); letter-spacing: 0.1em; margin-bottom: 24px; }
    .redirect-note span { color: var(--accent, #6b1f1f); font-weight: 500; }
    .thankyou-check { font-size: 64px; margin-bottom: 24px; color: var(--success, #3d5a3d); }

    /* Review summary */
    .review-pillar { margin-bottom: 28px; }
    .review-pillar-name { font-family: var(--mono); font-size: 10px; letter-spacing: 0.3em; color: var(--accent, #6b1f1f); text-transform: uppercase; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid var(--rule-soft, #ddd6c4); }
    .review-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .review-item:last-child { border-bottom: none; }
    .review-question { flex: 1; font-size: 14px; color: var(--ink-soft); line-height: 1.5; padding-right: 20px; }
    .review-question span { color: var(--ink-muted); font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; margin-right: 6px; }
    .review-answer { font-weight: 500; color: var(--ink); font-size: 14px; min-width: 120px; text-align: right; }
    .review-actions { display: flex; gap: 16px; justify-content: center; margin-top: 40px; }

    /* Question text with tooltip inline */
    .question-text-row { display: flex; align-items: flex-start; margin-bottom: 1.2rem; }
    .question-text-row .question-text { margin-bottom: 0; flex: 1; }

    /* Auto-scroll smooth */
    .question-card { scroll-margin-top: 100px; }

    @media (max-width: 600px) {
      .q-tooltip-text { width: 240px; }
      .likert-options { gap: 0; }
      .likert-circle { width: 40px; height: 40px; font-size: 12px; }
      .likert-label { font-size: 8px; max-width: 60px; }
      .select-pill { padding: 8px 14px; font-size: 13px; }
    }
  </style>
</head>
<body class="assessment-page">
  <header class="site-header">
    <div class="header-left">
      <a href="/dashboard" class="header-back">&larr; Dashboard</a>
      <span class="header-brand">BLUE OCEAN</span>
    </div>
    <div class="header-right">
      <span class="header-dossier">Dossier <strong><%= user.username %></strong></span>
    </div>
  </header>

  <main class="assessment-main">
    <!-- PHASE 1: Questions -->
    <div id="questionPhase">
      <div class="assessment-header">
        <p class="intro-label">MODULE <%= String(module.module_number).padStart(2, '0') %></p>
        <h1 class="assessment-title"><%= module.title %></h1>
        <p class="assessment-desc"><%= module.description %></p>
        <% if (isComplete) { %>
          <div class="info-banner">You have already completed this assessment. Your responses are shown below (read-only).</div>
        <% } %>
      </div>

      <div class="progress-container" id="progressContainer">
        <div class="progress-bar" id="progressBar"></div>
        <span class="progress-text" id="progressText">0 of <%= questions.length %></span>
      </div>

      <form id="assessmentForm" class="assessment-form">
        <%
          let currentPillar = '';
          questions.forEach(function(q, index) {
            const existingAnswer = responseMap[q.id] || '';
            let scaleLabels = [];
            try { scaleLabels = JSON.parse(q.scale_labels || '[]'); } catch(e) {}
            if (q.pillar !== currentPillar) {
              currentPillar = q.pillar;
        %>
          <div class="pillar-divider">
            <h3 class="pillar-name"><%= currentPillar %></h3>
          </div>
        <% } %>

          <div class="question-card" data-question-id="<%= q.id %>" data-question-num="<%= q.question_number %>" data-pillar="<%= q.pillar %>">
            <div class="question-number">Q<%= q.question_number %></div>
            <div class="question-text-row">
              <p class="question-text"><%= q.question_text %></p>
              <% if (q.tooltip) { %>
                <div class="q-tooltip-wrap">
                  <span class="q-tooltip-icon">i</span>
                  <div class="q-tooltip-text"><%= q.tooltip %></div>
                </div>
              <% } %>
            </div>

            <% if (q.response_type === 'scale') { %>
              <div class="likert-group">
                <div class="likert-options">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <label class="likert-option">
                      <input type="radio" name="q_<%= q.id %>" value="<%= i %>"
                        <%= existingAnswer == i ? 'checked' : '' %>
                        <%= isComplete ? 'disabled' : '' %>>
                      <span class="likert-circle"><%= i %></span>
                      <span class="likert-label"><%= scaleLabels[i-1] || '' %></span>
                    </label>
                  <% } %>
                </div>
              </div>

            <% } else if (q.response_type === 'single_select') { %>
              <div class="select-group">
                <% q.parsedOptions.forEach(function(opt) { %>
                  <label class="select-option">
                    <input type="radio" name="q_<%= q.id %>" value="<%= opt %>"
                      <%= existingAnswer === opt ? 'checked' : '' %>
                      <%= isComplete ? 'disabled' : '' %>>
                    <span class="select-pill"><%= opt %></span>
                  </label>
                <% }); %>
              </div>

            <% } else if (q.response_type === 'multi_select') { %>
              <div class="select-group multi">
                <% q.parsedOptions.forEach(function(opt) {
                  let checked = false;
                  try { checked = JSON.parse(existingAnswer || '[]').includes(opt); } catch(e) {}
                %>
                  <label class="select-option">
                    <input type="checkbox" name="q_<%= q.id %>" value="<%= opt %>"
                      <%= checked ? 'checked' : '' %>
                      <%= isComplete ? 'disabled' : '' %>>
                    <span class="select-pill"><%= opt %></span>
                  </label>
                <% }); %>
              </div>
            <% } %>
          </div>

        <% }); %>

        <% if (!isComplete) { %>
          <div class="submit-section">
            <button type="submit" class="btn-primary btn-submit" id="reviewBtn">
              REVIEW RESPONSES &rarr;
            </button>
          </div>
        <% } else { %>
          <div class="submit-section">
            <a href="/dashboard" class="btn-primary">BACK TO DASHBOARD &rarr;</a>
          </div>
        <% } %>
      </form>
    </div>

    <!-- PHASE 2: Review Summary -->
    <div id="reviewPhase" class="review-section">
      <div class="assessment-header">
        <p class="intro-label">REVIEW YOUR RESPONSES</p>
        <h1 class="assessment-title">Assessment Summary</h1>
        <p class="assessment-desc">Please review your responses below. If you need to make changes, click "Edit Responses" to go back.</p>
      </div>

      <div id="reviewContent"></div>

      <div class="review-actions">
        <button class="btn-primary" style="background:transparent;color:var(--ink);border:1px solid var(--ink);" onclick="goBackToEdit()">
          &larr; EDIT RESPONSES
        </button>
        <button class="btn-primary" id="finalSubmitBtn" onclick="submitFinal()">
          SUBMIT FINAL RESPONSES &rarr;
        </button>
      </div>
    </div>

    <!-- PHASE 3: Thank You -->
    <div id="thankyouPhase" class="thankyou-screen">
      <div class="thankyou-check">✓</div>
      <p class="intro-label">YOUR PRIVATE RECORD</p>
      <h1>Thank you, <em><%= user.first_name || 'Member' %></em></h1>
      <p class="thankyou-desc">Your AI Maturity Assessment has been recorded. Twenty-five responses across five pillars — Strategy, Use Cases, Data, Technology, People & Governance — are now shaping your personalised dossier.</p>
      <div class="thankyou-next">
        <h3>What happens next</h3>
        <p>Your maturity report is being prepared. It will benchmark your organisation against the cohort and global leaders.</p>
        <p style="margin-top:12px;">Module 2 — <em>Maturity Report</em> — is now unlocked in your dossier.</p>
      </div>
      <p class="redirect-note">Redirecting to your dossier in <span id="countdown">5</span> seconds...</p>
      <a href="/dashboard" class="btn-primary">RETURN TO DOSSIER &rarr;</a>
    </div>
  </main>

  <script>
    const form = document.getElementById('assessmentForm');
    const totalQuestions = <%= questions.length %>;
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');

    function updateProgress() {
      const cards = document.querySelectorAll('.question-card');
      let answered = 0;
      cards.forEach(card => {
        const inputs = card.querySelectorAll('input[type="radio"]:checked, input[type="checkbox"]:checked');
        if (inputs.length > 0) answered++;
      });
      const pct = Math.round((answered / totalQuestions) * 100);
      progressBar.style.width = pct + '%';
      progressText.textContent = answered + ' of ' + totalQuestions;
    }

    form.addEventListener('change', updateProgress);
    updateProgress();

    // Limit multi-select to max mentioned in question text
    document.querySelectorAll('.question-card').forEach(card => {
      const text = card.querySelector('.question-text').textContent;
      const match = text.match(/up to (\d+)/i);
      if (match) {
        const max = parseInt(match[1]);
        const boxes = card.querySelectorAll('input[type="checkbox"]');
        boxes.forEach(cb => {
          cb.addEventListener('change', () => {
            const checked = card.querySelectorAll('input[type="checkbox"]:checked').length;
            if (checked >= max) {
              boxes.forEach(c => { if (!c.checked) c.disabled = true; });
            } else {
              boxes.forEach(c => c.disabled = false);
            }
          });
        });
      }
    });

    // Auto-scroll to next question after answering
    const allCards = Array.from(document.querySelectorAll('.question-card'));
    allCards.forEach((card, idx) => {
      card.querySelectorAll('input[type="radio"]').forEach(input => {
        input.addEventListener('change', () => {
          if (idx < allCards.length - 1) {
            setTimeout(() => {
              allCards[idx + 1].scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 300);
          }
        });
      });
    });

    // Collect answers
    function collectAnswers() {
      const answers = {};
      const cards = document.querySelectorAll('.question-card');
      let allAnswered = true;
      cards.forEach(card => {
        const qId = card.dataset.questionId;
        const radios = card.querySelectorAll('input[type="radio"]:checked');
        const checkboxes = card.querySelectorAll('input[type="checkbox"]:checked');
        if (radios.length > 0) {
          answers[qId] = radios[0].value;
        } else if (checkboxes.length > 0) {
          answers[qId] = Array.from(checkboxes).map(cb => cb.value);
        } else {
          allAnswered = false;
          card.classList.add('unanswered');
        }
      });
      return { answers, allAnswered };
    }

    <% if (!isComplete) { %>
    // PHASE 1 → PHASE 2: Review
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      document.querySelectorAll('.unanswered').forEach(el => el.classList.remove('unanswered'));
      const { answers, allAnswered } = collectAnswers();

      if (!allAnswered) {
        const first = document.querySelector('.unanswered');
        if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
        alert('Please answer all questions before reviewing.');
        return;
      }

      // Build review summary
      const cards = document.querySelectorAll('.question-card');
      const pillars = {};
      cards.forEach(card => {
        const pillar = card.dataset.pillar;
        const qNum = card.dataset.questionNum;
        const qText = card.querySelector('.question-text').textContent;
        const qId = card.dataset.questionId;
        let answer = answers[qId];
        if (Array.isArray(answer)) answer = answer.join(', ');
        if (!pillars[pillar]) pillars[pillar] = [];
        pillars[pillar].push({ qNum, qText, answer });
      });

      let html = '';
      for (const [pillar, items] of Object.entries(pillars)) {
        html += '<div class="review-pillar">';
        html += '<div class="review-pillar-name">' + pillar + '</div>';
        items.forEach(item => {
          html += '<div class="review-item">';
          html += '<div class="review-question"><span>Q' + item.qNum + '</span> ' + item.qText + '</div>';
          html += '<div class="review-answer">' + item.answer + '</div>';
          html += '</div>';
        });
        html += '</div>';
      }

      document.getElementById('reviewContent').innerHTML = html;
      document.getElementById('questionPhase').style.display = 'none';
      document.getElementById('reviewPhase').classList.add('active');
      window.scrollTo({ top: 0, behavior: 'instant' });
    });

    // PHASE 2 → PHASE 1: Edit
    function goBackToEdit() {
      document.getElementById('reviewPhase').classList.remove('active');
      document.getElementById('questionPhase').style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'instant' });
    }

    // PHASE 2 → PHASE 3: Submit
    async function submitFinal() {
      const btn = document.getElementById('finalSubmitBtn');
      btn.disabled = true;
      btn.textContent = 'SUBMITTING...';
      const { answers } = collectAnswers();

      try {
        const res = await fetch('/module/<%= module.module_number %>/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ answers })
        });
        const data = await res.json();
        if (data.success) {
          document.getElementById('reviewPhase').classList.remove('active');
          document.getElementById('thankyouPhase').classList.add('active');
          window.scrollTo({ top: 0, behavior: 'instant' });

          let seconds = 5;
          const countdownEl = document.getElementById('countdown');
          const timer = setInterval(() => {
            seconds--;
            countdownEl.textContent = seconds;
            if (seconds <= 0) {
              clearInterval(timer);
              window.location.href = '/dashboard';
            }
          }, 1000);
        } else {
          alert(data.error || 'Submission failed. Please try again.');
          btn.disabled = false;
          btn.textContent = 'SUBMIT FINAL RESPONSES →';
        }
      } catch (err) {
        alert('Network error. Please check your connection and try again.');
        btn.disabled = false;
        btn.textContent = 'SUBMIT FINAL RESPONSES →';
      }
    }
    <% } %>
  </script>
</body>
</html>